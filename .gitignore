# ── Secrets and runtime config ────────────────────────────────────────────────

# Bot phone number — Docker secret
secrets/

# Real env config (UUIDs, group IDs, etc.) — only env.example is checked in
.env

# ── Signal account state ─────────────────────────────────────────────────────

# signal-cli's account keys, identity store, and message database. Anyone
# with these files can impersonate the bot's Signal account. NEVER commit.
signal-config/

# ── Per-deployment data ──────────────────────────────────────────────────────

# Auto-created files holding the shared document, the bot's persona, and
# the auto-onboarded group list. Per-deployment user content, not project
# code.
data/

# ── Python ────────────────────────────────────────────────────────────────────

__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/

# ── OS ────────────────────────────────────────────────────────────────────────

.DS_Store
Thumbs.db

# ── Local notes ───────────────────────────────────────────────────────────────

# Personal hardening checklist for whoever deploys this. Lives alongside the
# repo so it's easy to find but not part of public history.
SECURITY-TODO.md

# Raw `docker scout cves` output. The published summary lives in
# CVE-ASSESSMENT.md; the verbose scanner output is per-machine / per-arch
# and not useful as version-controlled history.
cve_assessment.txt
*.scout.txt
rootless_cves.txt
