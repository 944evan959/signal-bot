# Copy this file to .env and fill in the values you need.
# BOT_NUMBER is NOT here — it's stored as a Docker secret in secrets/bot_number.txt

# ── Group access control ──────────────────────────────────────────────────────

# Signal group ID the bot responds in. **Optional** — once OWNER_ID is set,
# you can also approve groups at runtime by sending `/group claim` in the
# group as the owner. Approved groups persist in data/groups.txt. Use this
# env var only if you want to pin a specific group via config rather than
# claim it interactively.
ALLOWED_GROUP=

# Comma-separated identifiers allowed to run /doc edit. Match either the
# phone number or the UUID — whichever signal-cli surfaces for that account.
# Users with "Find by Phone Number" disabled will only have a UUID, not a number.
ADMIN_IDS=

# DM access. Only this identifier may DM the bot directly. Same format as
# ADMIN_IDS — phone number or UUID. Leave blank to disable DMs entirely.
OWNER_ID=

# The bot's own Signal UUID. When set, the bot responds to native Signal
# @mentions (selected from the in-app contact picker) regardless of name.
# Leave blank on first run — send a group message that @mentions the bot,
# then read the bot's logs for a line like:
#   Mentions in message: ['<uuid>']
# Copy that UUID here and restart. Until set, the bot falls back to text
# matching `@<BOT_NAME>`, so the legacy trigger keeps working.
BOT_UUID=

# ── Ollama ────────────────────────────────────────────────────────────────────

# Ollama runs natively on the host (Mac/Linux); Docker reaches it via the
# host gateway. Change to http://localhost:11434/v1 if Ollama runs in Docker too.
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

MODEL_EDIT=llama3.3
MODEL_SEARCH=llama3.3

# Web search mode:
#   auto       — keyword heuristic; searches only on time-sensitive queries
#   duckduckgo — always search before answering
#   (unset)    — answer from training only, with a stale-data warning
SEARCH_FALLBACK=auto

# ── Bot config ────────────────────────────────────────────────────────────────

BOT_NAME=Claude

# Inline-view truncation point. Anything beyond this is sent via /doc share.
MAX_INLINE_CHARS=1500

# Cap on the user's instruction length for /doc edit.
MAX_INSTRUCTION=500

# Hard ceiling on the persisted document size (chars). write_doc() refuses
# anything larger, so a runaway model output can't blow up the file.
MAX_DOC_CHARS=50000

# Maximum doc size accepted as input to /doc edit. Edits on docs larger
# than this are refused (silent truncation + full-doc replace would lose data).
MAX_DOC_INPUT_CHARS=20000

# Per-call ceilings on every Ollama chat completion. max_tokens stops
# runaway generation (e.g. "recite the entire bee movie script"); timeout
# stops a stalled / looping model from hanging the bot indefinitely.
# max_tokens ~3000 ≈ 12K chars output. Bound runaway generation while
# still fitting most doc edits and Q&A. Bump if you hit truncation on
# large /doc edit operations.
LLM_MAX_TOKENS=3000
LLM_TIMEOUT=180

# Send a "still working" message in chat if /doc edit hasn't completed in
# this many seconds. Lets users know the bot didn't crash. Set to 0 to disable.
PROGRESS_NUDGE_SECONDS=30

# Maximum length of a single user query (Q&A or DM) sent to the LLM.
# Defends against pathologically long messages and reduces the
# prompt-injection surface area.
MAX_QUERY_CHARS=1000

# Per-sender sliding-window rate limit. The owner is exempt; everyone else
# is capped at RATE_LIMIT_MAX messages per RATE_LIMIT_WINDOW seconds.
# Set RATE_LIMIT_MAX=0 to disable rate limiting.
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# The bot's persona / system prompt. Auto-created at first run with a starter
# template — edit data/persona.md to customise the bot's identity and teach
# it about the people in your group. Re-read on every query, no restart needed.
# (You normally don't need to override this path.)
# PERSONA_PATH=/data/persona.md
